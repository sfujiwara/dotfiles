;; Show current line and column numbers.
(column-number-mode t)
(line-number-mode t)

;; Show line numbers.
(global-linum-mode t)
(setq linum-format "%4d ")

;; Highlight parentheses.
(show-paren-mode t)

;; Use theme.
(load-theme 'misterioso t)
